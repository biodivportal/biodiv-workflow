/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    biodiv-workflow Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Pipeline parameters
params {
    // --- Input / Output ---
    input                  = null           // Path to input CSV file
    outdir                 = 'results'      // Output directory

    // --- Column names in the input CSV ---
    // Produced by bin/convert_xlsx.py from Belege_aus_D_2.csv:
    //   id_column          = 'id'           (from HerbariumID)
    //   land_text_column   = 'text_land'    (FundortUNdOeko → Locality fallback)
    //   biodiv_text_column = 'text_biodiv'  (FullNameCache — species name)
    id_column              = 'id'
    land_text_column       = 'text_land'
    biodiv_text_column     = 'text_biodiv'

    // --- Row limit (null = process all rows) ---
    max_records            = null

    // --- Python interpreter ---
    // Override if 'python3' is not on PATH (e.g. Windows: full path to python.exe)
    python_bin             = 'python3'

    // --- BiodivPortal Annotator ---
    biodivportal_url        = 'https://data.biodivportal.gfbio.org'
    biodivportal_apikey     = ''            // Set your API key here or via --biodivportal_apikey
    biodivportal_ontologies = ''            // Optional: comma-separated ontology IDs to restrict annotation

    // --- Land Taxonomy Classifier (local FastAPI service) ---
    land_classifier_url    = 'http://127.0.0.1:8000'
    land_classifier_top_k  = 5
    land_classifier_model  = 'gpt-4o-mini'

    // --- Resource defaults ---
    max_memory             = '8.GB'
    max_cpus               = 4
    max_time               = '2.h'
}

// Process defaults
process {
    cpus   = 1
    memory = '2.GB'
    time   = '30.m'

    errorStrategy = 'retry'
    maxRetries    = 2
}

// Execution profiles
profiles {

    // Run locally without Docker (default)
    standard {
        process.executor = 'local'
    }

    // Run with Docker
    docker {
        docker.enabled     = true
        docker.runOptions  = '-u $(id -u):$(id -g)'
        process.container  = 'python:3.11-slim'
    }

    // Run on an HPC cluster with SLURM
    slurm {
        process.executor = 'slurm'
        process.queue    = 'short'
    }

    // -----------------------------------------------------------------------
    // Real input: full Belege_aus_D dataset
    // Prerequisite: run bin/convert_xlsx.py first (see README)
    // Usage: nextflow run main.nf -profile belege --outdir results/
    // -----------------------------------------------------------------------
    belege {
        params.input              = "${projectDir}/assets/Belege_aus_D.csv"
        params.outdir             = 'results'
        params.id_column          = 'id'
        params.land_text_column   = 'text_land'
        params.biodiv_text_column = 'text_biodiv'
    }

    // -----------------------------------------------------------------------
    // Quick smoke-test: first 50 records from the real dataset
    // Usage: nextflow run main.nf -profile belege_test --outdir results_test/
    // -----------------------------------------------------------------------
    belege_test {
        params.input              = "${projectDir}/assets/Belege_aus_D.csv"
        params.outdir             = 'results_test'
        params.id_column          = 'id'
        params.land_text_column   = 'text_land'
        params.biodiv_text_column = 'text_biodiv'
        params.max_records        = 50
    }

    // CI / testing profile (uses small example CSV)
    test {
        params.input              = "${projectDir}/assets/example_input.csv"
        params.outdir             = 'test_results'
        params.id_column          = 'id'
        params.land_text_column   = 'text_land'
        params.biodiv_text_column = 'text_biodiv'
    }
}

// Manifest
manifest {
    name            = 'biodiv-workflow'
    author          = 'Your Name'
    homePage        = 'https://github.com/YOUR_ORG/biodiv-workflow'
    description     = 'Enriches herbarium records (Belege_aus_D) via BiodivPortal Annotator and Land Taxonomy Classifier'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// Capture exit codes from pipes
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Logging
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
}
