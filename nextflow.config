params {
    // Input / Output
    input                   = null
    outdir                  = "results"

    // Column names in the input CSV
    id_column               = "HerbariumID"
    land_text_column        = "Locality"
    biodiv_text_column      = "FullNameCache"

    // Row limit (null = all rows)
    max_records             = null

    // BiodivPortal Annotator
    biodivportal_url        = "https://data.biodivportal.gfbio.org"
    biodivportal_apikey     = ""
    biodivportal_ontologies = ""

    // Land Taxonomy Classifier (local FastAPI service)
    land_classifier_url     = "http://127.0.0.1:8000"
    land_classifier_top_k   = 5
    land_classifier_model   = "gpt-4o-mini"

    // Notifications
    email                   = ""
    mailfrom                = "noreply@biodivportal.org"
}

// Process resource labels
process {
    errorStrategy = 'retry'
    maxRetries    = 2

    withLabel: 'process_single' {
        cpus   = 1
        memory = '2.GB'
        time   = '30.m'
    }
}

// Mail — configure your SMTP server here
// For Gmail: create an App Password at https://myaccount.google.com/apppasswords
mail {
    smtp.host           = 'smtp.gmail.com'
    smtp.port           = 587
    smtp.user           = ''        // your Gmail address
    smtp.password       = ''        // your App Password
    smtp.auth           = true
    smtp.starttls.enable = true
}

profiles {
    docker {
        docker.enabled     = true
        docker.runOptions  = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    test {
        params.input       = "${projectDir}/assets/test_20.csv"
        params.outdir      = "test_results"
        params.max_records = 5
    }
}
